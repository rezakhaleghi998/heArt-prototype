APP_ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/heart
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=https://.*\.up\.railway\.app
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=heart-demo
STORAGE_REGION=eu-south-1
LOCAL_STORAGE_DIR=/tmp/heart-uploads
MAX_UPLOAD_MB=250
DEBUG_ERRORS=true
RESET_INCOMPATIBLE_SCHEMA=true
